import { useState } from "react";
import FeesPageLayout from "@/components/fees/FeesPageLayout";
import { Card } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { useNavigate } from "react-router-dom";
import { useStudentAuth } from "@/hooks/use-student-auth";
import { leadsStore } from "@/lib/leads";
import { studentAccountsRepo } from "@/lib/student-auth";
import { type FeeTrack, getCourse, formatRupee } from "@/lib/fees-courses";

function extractCourseFromMessage(msg: string): { name: string; track: FeeTrack } | null {
  const match = msg.match(/Course:\s*(.+?)\s*\((Adults|Kids)\)/i);
  if (!match) return null;
  return { name: match[1].trim(), track: match[2].toLowerCase() === "kids" ? "kids" : "adults" };
}

function lookupCourse(email: string): { name: string; monthlyFee: number } | null {
  const account = studentAccountsRepo.findByEmail(email);
  const snap = account?.enrollmentSnapshot;
  if (snap) {
    return { name: snap.courseName, monthlyFee: snap.monthlyRupee };
  }
  const lead = leadsStore.findByEmail(email);
  const parsed = lead ? extractCourseFromMessage(lead.message) : null;
  if (parsed) {
    const fc = getCourse(parsed.track, parsed.name);
    if (fc) return { name: fc.name, monthlyFee: fc.monthlyRupee };
  }
  return null;
}

const ExistingStudent = () => {
  const navigate = useNavigate();
  const { session } = useStudentAuth();
  const [rollInput, setRollInput] = useState("");
  const [rollError, setRollError] = useState<string | null>(null);
  const [resolvedCourse, setResolvedCourse] = useState<{ name: string; monthlyFee: number } | null>(null);

  // Logged-in: resolve course once
  const [sessionCourse] = useState(() => (session ? lookupCourse(session.email) : null));

  const displayCourse = resolvedCourse || sessionCourse;

  const rollNumber = session ? leadsStore.findByEmail(session.email)?.rollNumber ?? null : null;

  // Non-logged-in: resolve course when roll input changes
  const handleRollLookup = () => {
    if (session) return;
    const trimmed = rollInput.trim();
    if (!trimmed) {
      setResolvedCourse(null);
      setRollError(null);
      return;
    }
    const allLeads = leadsStore.list();
    const matched = allLeads.find((l) => l.rollNumber === trimmed);
    if (matched) {
      const course = lookupCourse(matched.email);
      setResolvedCourse(course || null);
      setRollError(null);
    } else {
      setResolvedCourse(null);
      setRollError("Roll number not found.");
    }
  };

  const handleContinue = () => {
    if (!session) {
      if (!rollInput.trim()) {
        setRollError("Please enter your roll number.");
        return;
      }
      handleRollLookup();
      if (rolledError) return;
      // TODO: Wire up Razorpay gateway payment page
      return;
    }
    // TODO: Wire up Razorpay gateway payment page for logged-in user
  };

  return (
    <FeesPageLayout
      eyebrow="Existing Student"
      title="Pay Your Monthly Fees"
      description="Continue your riyaaz with us."
    >
      <div className="max-w-2xl mx-auto">
        <Card className="p-6">
          <p className="text-sm text-[#4A5E52]">Your Roll Number</p>
          {session ? (
            <p className="mt-2 text-3xl font-bold text-[#C9922A]">
              {rollNumber || "Not assigned yet"}
            </p>
          ) : (
            <div className="mt-2 space-y-2">
              <Label htmlFor="roll-input">Enter your roll number to continue</Label>
              <Input
                id="roll-input"
                value={rollInput}
                onChange={(e) => { setRollInput(e.target.value); setRollError(null); setResolvedCourse(null); }}
                onBlur={handleRollLookup}
                placeholder="e.g. SS-2026-001"
                className="max-w-xs"
              />
              {rollError && <p className="text-sm text-destructive">{rollError}</p>}
            </div>
          )}
        </Card>

        <Card className="mt-6 p-6 border-2 border-primary/20">
          <h2 className="font-display text-2xl font-semibold text-foreground mb-2">
            Monthly Fee Payment
          </h2>
          {displayCourse ? (
            <div className="flex justify-between items-center py-4">
              <span className="text-foreground font-medium">{displayCourse.name}</span>
              <span className="text-2xl font-bold text-[#C9922A]">{formatRupee(displayCourse.monthlyFee)} / month</span>
            </div>
          ) : (
            <p className="text-muted-foreground text-sm py-4">
              {session ? "No course enrolled yet." : "Enter your roll number above to see your course details."}
            </p>
          )}
          <div className="flex flex-col sm:flex-row gap-3 mt-4">
            <Button variant="hero" onClick={handleContinue}>
              Continue to Payment
            </Button>
            <Button variant="outline" onClick={() => navigate(-1)}>
              Cancel
            </Button>
          </div>
        </Card>
      </div>
    </FeesPageLayout>
  );
};

export default ExistingStudent;